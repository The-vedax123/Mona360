# Mona360 — Backend environment (all optional)

# Port the Express server listens on
PORT=4000

# Comma-separated list of allowed CORS origins (defaults to * in development)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Mona AI — Google Gemini (primary provider)
# -----------------------------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
# When set, Mona AI uses Gemini for smart, dynamic responses.
# When empty, Mona AI falls back to a data-driven rule-based advisor.
# The key is used ONLY on the backend and is never exposed to the frontend.
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Supabase (optional) — lets the backend fetch business data server-side
# -----------------------------------------------------------------------------
SUPABASE_URL=
# Prefer the service-role key (server-only, never expose it publicly).
SUPABASE_SERVICE_ROLE_KEY=
# Or, if you must, the anon key:
SUPABASE_ANON_KEY=

# Optional legacy OpenAI key (not required)
OPENAI_API_KEY=
