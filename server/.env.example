# Mona360 — Backend environment (all optional)

# Port the Express server listens on
PORT=4000

# Comma-separated list of allowed CORS origins (defaults to * in development)
CORS_ORIGIN=http://localhost:5173

# Optional: OpenAI-compatible API key. If set, the AI advisor can be upgraded
# to call a real LLM. When empty, the backend returns smart, data-driven mock
# responses derived from the posted business metrics.
OPENAI_API_KEY=
