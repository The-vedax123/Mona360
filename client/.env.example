# Mona360 — Frontend environment
# All variables are OPTIONAL. Without them, the app runs in a fully-featured
# local demo mode (data persisted in the browser). Add Supabase keys to enable
# real authentication and cloud persistence.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=

# Backend API base URL (defaults to /api via the Vite dev proxy)
VITE_API_BASE_URL=/api
